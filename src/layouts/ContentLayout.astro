---
// ContentLayout.astro — 3-column grid: sidebar | content | TOC
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import Sidebar from '../components/content/Sidebar.astro';
import TableOfContents from '../components/content/TableOfContents.astro';

export interface Props {
  title?: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  sidebarSections: {
    title: string;
    links: { label: string; href: string; active?: boolean }[];
  }[];
}

const { title, description, headings = [], sidebarSections } = Astro.props;
const hasToc = headings.length > 0;
---

<BaseLayout title={title} description={description}>
  <Navbar />
  <div class:list={['content-page', { 'has-toc': hasToc }]}>
    <Sidebar sections={sidebarSections} />
    <main class="content-main">
      <article class="prose-mind">
        <slot />
      </article>
    </main>
    {hasToc && <TableOfContents headings={headings} />}
  </div>
  <Footer />
</BaseLayout>

<style>
  /*
   * 3-column CSS grid:
   *   sidebar  | content (1fr) | TOC
   * Columns use minmax so they shrink if needed but never collapse.
   * The Sidebar and TOC control their own sticky/scroll behaviour
   * and need no fixed widths here.
  */
  .content-page {
    width: 100%;
    box-sizing: border-box;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(200px, 240px) 1fr;
    gap: 0;
    padding: 2.5rem 3rem var(--spacing-section);
    min-height: calc(100vh - 64px);
    align-items: start;
  }

  /* When TOC is present, add a third column */
  .content-page.has-toc {
    grid-template-columns: minmax(200px, 240px) 1fr minmax(180px, 220px);
  }

  .content-main {
    padding: 0 2.5rem;
    min-width: 0; /* prevent overflow in grid */
  }

  /* ---- Responsive ---- */

  /* Hide TOC on narrower viewports */
  @media (max-width: 1280px) {
    .content-page.has-toc {
      grid-template-columns: minmax(200px, 240px) 1fr;
    }
  }

  /* Hide sidebar too on tablets */
  @media (max-width: 1024px) {
    .content-page,
    .content-page.has-toc {
      grid-template-columns: 1fr;
    }

    .content-main {
      padding: 0;
    }
  }
</style>
