---
// 500.astro — Custom branded 500 error page
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
---

<BaseLayout title="Server Error — MIND" description="Something went wrong on our end.">
  <Navbar />
  <main class="error-page">
    <div class="error-inner">
      <h1 class="error-code text-gradient">500</h1>
      <h2 class="error-title">Something went wrong</h2>
      <p class="error-message">
        We're experiencing an issue on our end. Please try again in a few moments.
      </p>
      <div class="error-actions">
        <a href="/" class="btn-primary">
          <i class="ph ph-house"></i>
          Back to Home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .error-page {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .error-inner {
    max-width: 500px;
  }

  .error-code {
    font-size: 8rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
  }

  .error-title {
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .error-message {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .error-code {
      font-size: 5rem;
    }
  }
</style>
