---
// TableOfContents.astro — Right-side sticky TOC auto-generated from headings

export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <h4 class="toc-title">On this page</h4>
    <ul class="toc-list">
      {tocHeadings.map(heading => (
        <li class:list={['toc-item', { 'toc-item-nested': heading.depth === 3 }]}>
          <a href={`#${heading.slug}`} class="toc-link">{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    /* fills its grid column in ContentLayout */
    position: sticky;
    top: 80px;
    height: fit-content;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
    padding-left: 2rem;
    border-left: 1px solid var(--color-border);
  }

  .toc-title {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .toc-item {
    padding-left: 0;
  }

  .toc-item-nested {
    padding-left: 1rem;
  }

  .toc-link {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
    line-height: 1.5;
  }

  .toc-link:hover {
    color: var(--color-electric);
  }

  @media (max-width: 1280px) {
    .toc {
      display: none;
    }
  }
</style>
