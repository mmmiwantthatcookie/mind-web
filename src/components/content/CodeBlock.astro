---
// CodeBlock.astro — Syntax-highlighted code block with copy button

export interface Props {
  code: string;
  lang?: string;
}

const { code, lang = '' } = Astro.props;
const blockId = `code-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="code-block">
  <div class="code-block-header">
    {lang && <span class="code-block-lang">{lang}</span>}
    <button class="code-copy-btn" data-code-id={blockId} aria-label="Copy code">
      <i class="ph ph-copy code-copy-icon"></i>
      <span class="code-copy-text">Copy</span>
    </button>
  </div>
  <pre id={blockId}><code class={lang ? `language-${lang}` : ''}>{code}</code></pre>
</div>

<style>
  .code-block {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    background: var(--color-elevated);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-caption);
  }

  .code-block-lang {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .code-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.5rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .code-copy-btn:hover {
    color: var(--color-electric);
    border-color: var(--color-electric);
  }

  pre {
    margin: 0;
    padding: 1.25rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    background: var(--color-surface);
  }

  code {
    font-family: inherit;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.code-copy-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const codeId = btn.getAttribute('data-code-id');
    if (!codeId) return;

    const codeEl = document.getElementById(codeId);
    if (!codeEl) return;

    navigator.clipboard.writeText(codeEl.textContent || '').then(() => {
      const icon = btn.querySelector('.code-copy-icon') as HTMLElement;
      const text = btn.querySelector('.code-copy-text') as HTMLElement;
      if (icon) icon.className = 'ph ph-check code-copy-icon';
      if (text) text.textContent = 'Copied!';
      setTimeout(() => {
        if (icon) icon.className = 'ph ph-copy code-copy-icon';
        if (text) text.textContent = 'Copy';
      }, 2000);
    });
  });
</script>
