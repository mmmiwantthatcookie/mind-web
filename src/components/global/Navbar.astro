---
// Navbar.astro — Sticky navigation with glassmorphism backdrop
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

const navLinks = [
  { label: 'Docs', href: '/docs/getting-started' },
  { label: 'Guides', href: '/guides/quick-start' },
  { label: 'Changelog', href: '/changelog' },
];
---

<nav class="navbar" aria-label="Main navigation">
  <div class="navbar-inner">
    <!-- Logotype -->
    <a href="/" class="navbar-logo" aria-label="MIND Home">
      MIND
    </a>

    <!-- Desktop nav links -->
    <div class="navbar-links" id="navbar-links">
      {navLinks.map(link => (
        <a href={link.href} class="navbar-link">{link.label}</a>
      ))}
    </div>

    <!-- Right-side actions -->
    <div class="navbar-actions">
      <LanguageToggle />
      <ThemeToggle />
      <a href="mailto:mind-project@example.com" class="btn-primary navbar-cta">
        Request Demo
      </a>
      <!-- Mobile hamburger -->
      <button class="navbar-hamburger" id="navbar-hamburger" aria-label="Open menu" aria-expanded="false">
        <i class="ph ph-list"></i>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="navbar-mobile" id="navbar-mobile">
    {navLinks.map(link => (
      <a href={link.href} class="navbar-mobile-link">{link.label}</a>
    ))}
    <a href="mailto:mind-project@example.com" class="btn-primary" style="margin-top: 1rem; justify-content: center;">
      Request Demo
    </a>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 250, 250, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.2s ease;
  }

  :global(.dark) .navbar {
    background: rgba(9, 9, 11, 0.85);
  }

  .navbar-inner {
    max-width: var(--container-content);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 1.5rem;
  }

  .navbar-logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }

  .navbar-logo:hover {
    color: var(--color-electric);
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .navbar-link:hover {
    color: var(--color-electric);
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .navbar-cta {
    padding: 0.5rem 1.25rem;
    font-size: var(--text-sm);
  }

  .navbar-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    cursor: pointer;
    color: var(--color-text-secondary);
    font-size: 1.5rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .navbar-hamburger:hover {
    color: var(--color-electric);
    border-color: var(--color-electric);
  }

  .navbar-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .navbar-mobile.open {
    display: flex;
  }

  .navbar-mobile-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s ease;
  }

  .navbar-mobile-link:hover {
    color: var(--color-electric);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar-links {
      display: none;
    }

    .navbar-cta {
      display: none;
    }

    .navbar-hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('navbar-hamburger');
  const mobileMenu = document.getElementById('navbar-mobile');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    mobileMenu?.classList.toggle('open', !isOpen);
    hamburger.setAttribute('aria-expanded', String(!isOpen));

    // Swap icon
    const icon = hamburger.querySelector('i');
    if (icon) {
      icon.className = isOpen ? 'ph ph-list' : 'ph ph-x';
    }
  });
</script>
