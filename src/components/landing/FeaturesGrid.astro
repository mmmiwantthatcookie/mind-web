---
// FeaturesGrid.astro — 3-column feature card grid with hover animations

const features = [
  {
    icon: 'ph-brain',
    title: 'Multi-LLM Backend',
    description: 'Leverage multiple language models simultaneously for cross-validated, robust analysis. Supports OpenAI, Anthropic, and open-source alternatives.',
  },
  {
    icon: 'ph-translate',
    title: 'Polylingual Topic Modeling',
    description: 'Cluster semantically related content across languages using state-of-the-art multilingual embeddings and topic modeling.',
  },
  {
    icon: 'ph-magnifying-glass',
    title: 'Hybrid Retrieval',
    description: 'Combine dense vector search with sparse keyword matching for comprehensive document retrieval that catches subtle inconsistencies.',
  },
  {
    icon: 'ph-database',
    title: 'Modular Data Ingestion',
    description: 'Plug in diverse data sources — PDFs, wikis, databases, APIs. Extensible pipeline adapts to your existing infrastructure.',
  },
  {
    icon: 'ph-monitor',
    title: 'Interactive Web Application',
    description: 'Review, filter, and resolve detected discrepancies through an intuitive dashboard with full audit trail.',
  },
  {
    icon: 'ph-puzzle-piece',
    title: 'Extensible Architecture',
    description: 'Modular, Docker-based deployment. Add new LLM providers, data sources, or analysis modules without modifying the core pipeline.',
  },
];
---

<section class="features" id="features">
  <div class="features-inner">
    <h2 class="features-heading" data-animate>
      Built for <span class="accent-text">Enterprise Scale</span>
    </h2>
    <p class="features-subtitle" data-animate data-delay="1">
      Every component designed for reliability, performance, and extensibility.
    </p>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div class="glass-card feature-card" data-animate data-delay={String(i % 3 + 1)}>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--spacing-section) 1.5rem;
  }

  .features-inner {
    max-width: var(--container-content);
    margin: 0 auto;
  }

  .features-heading {
    font-size: var(--text-h2);
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 600;
    text-align: center;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .features-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: var(--text-body);
    max-width: 50ch;
    margin: 0 auto var(--spacing-component);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover), var(--shadow-glow-sm);
  }

  .feature-icon {
    font-size: 2.5rem;
    color: var(--color-electric);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .feature-title {
    font-size: var(--text-h4);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .feature-description {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
