---
// ArchitectureDiagram.astro — Animated SVG pipeline diagram with scroll-triggered reveal
---

<section class="architecture" id="architecture">
  <div class="architecture-inner">
    <h2 class="architecture-heading" data-animate>
      How <span class="accent-text">MIND</span> Works
    </h2>
    <p class="architecture-subtitle" data-animate data-delay="1">
      A modular pipeline that ingests, analyzes, and surfaces knowledge base inconsistencies.
    </p>

    <div class="architecture-diagram" data-animate data-delay="2">
      <svg viewBox="0 0 900 320" xmlns="http://www.w3.org/2000/svg" class="pipeline-svg" aria-label="MIND architecture pipeline diagram">
        <!-- Connection lines -->
        <line x1="160" y1="160" x2="265" y2="160" class="flow-line" />
        <line x1="385" y1="160" x2="490" y2="160" class="flow-line flow-line-2" />
        <line x1="610" y1="160" x2="715" y2="160" class="flow-line flow-line-3" />

        <!-- Stage 1: Data Ingestion -->
        <g class="pipeline-node node-1">
          <rect x="20" y="100" width="140" height="120" rx="12" class="node-bg" />
          <text x="90" y="145" text-anchor="middle" class="node-label">Data</text>
          <text x="90" y="168" text-anchor="middle" class="node-label">Ingestion</text>
          <text x="90" y="200" text-anchor="middle" class="node-sublabel">PDFs · Wikis · APIs</text>
        </g>

        <!-- Arrow 1 -->
        <polygon points="260,155 270,160 260,165" class="flow-arrow arrow-1" />

        <!-- Stage 2: Topic Modeling -->
        <g class="pipeline-node node-2">
          <rect x="270" y="100" width="140" height="120" rx="12" class="node-bg node-bg-accent" />
          <text x="340" y="145" text-anchor="middle" class="node-label">Topic</text>
          <text x="340" y="168" text-anchor="middle" class="node-label">Modeling</text>
          <text x="340" y="200" text-anchor="middle" class="node-sublabel">Multilingual NLP</text>
        </g>

        <!-- Arrow 2 -->
        <polygon points="485,155 495,160 485,165" class="flow-arrow arrow-2" />

        <!-- Stage 3: Discrepancy Detection -->
        <g class="pipeline-node node-3">
          <rect x="495" y="100" width="140" height="120" rx="12" class="node-bg node-bg-accent" />
          <text x="565" y="145" text-anchor="middle" class="node-label">Discrepancy</text>
          <text x="565" y="168" text-anchor="middle" class="node-label">Detection</text>
          <text x="565" y="200" text-anchor="middle" class="node-sublabel">Multi-LLM Analysis</text>
        </g>

        <!-- Arrow 3 -->
        <polygon points="710,155 720,160 710,165" class="flow-arrow arrow-3" />

        <!-- Stage 4: Dashboard -->
        <g class="pipeline-node node-4">
          <rect x="720" y="100" width="140" height="120" rx="12" class="node-bg" />
          <text x="790" y="145" text-anchor="middle" class="node-label">Interactive</text>
          <text x="790" y="168" text-anchor="middle" class="node-label">Dashboard</text>
          <text x="790" y="200" text-anchor="middle" class="node-sublabel">Review · Resolve</text>
        </g>

        <!-- Bottom label -->
        <text x="450" y="280" text-anchor="middle" class="diagram-footer">
          Docker-Based Deployment · Extensible Modules · Configurable Pipeline
        </text>
      </svg>
    </div>
  </div>
</section>

<style>
  .architecture {
    padding: var(--spacing-section) 1.5rem;
  }

  .architecture-inner {
    max-width: var(--container-content);
    margin: 0 auto;
  }

  .architecture-heading {
    font-size: var(--text-h2);
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 600;
    text-align: center;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .architecture-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: var(--text-body);
    max-width: 55ch;
    margin: 0 auto var(--spacing-component);
  }

  .architecture-diagram {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 2rem;
    overflow-x: auto;
  }

  .pipeline-svg {
    width: 100%;
    max-width: 900px;
    height: auto;
    margin: 0 auto;
    display: block;
  }

  /* Node backgrounds */
  .node-bg {
    fill: var(--color-elevated);
    stroke: var(--color-border);
    stroke-width: 1;
    transition: fill 0.3s ease;
  }

  .node-bg-accent {
    stroke: var(--color-electric);
    stroke-width: 1.5;
  }

  /* Text */
  .node-label {
    fill: var(--color-text-primary);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
  }

  .node-sublabel {
    fill: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .diagram-footer {
    fill: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  /* Flow lines */
  .flow-line {
    stroke: var(--color-electric);
    stroke-width: 2;
    stroke-dasharray: 8 4;
    stroke-dashoffset: 24;
  }

  .flow-arrow {
    fill: var(--color-electric);
    opacity: 0;
  }

  /* Animation on scroll */
  .architecture-diagram.animate-in .pipeline-node {
    animation: nodeReveal 0.5s ease-out forwards;
    opacity: 0;
  }

  .architecture-diagram.animate-in .node-1 { animation-delay: 0s; }
  .architecture-diagram.animate-in .node-2 { animation-delay: 0.6s; }
  .architecture-diagram.animate-in .node-3 { animation-delay: 1.2s; }
  .architecture-diagram.animate-in .node-4 { animation-delay: 1.8s; }

  .architecture-diagram.animate-in .flow-line {
    animation: dashFlow 1.5s ease-out forwards;
  }

  .architecture-diagram.animate-in .flow-line-2 { animation-delay: 0.6s; }
  .architecture-diagram.animate-in .flow-line-3 { animation-delay: 1.2s; }

  .architecture-diagram.animate-in .flow-arrow {
    animation: arrowReveal 0.3s ease-out forwards;
  }

  .architecture-diagram.animate-in .arrow-1 { animation-delay: 0.5s; }
  .architecture-diagram.animate-in .arrow-2 { animation-delay: 1.1s; }
  .architecture-diagram.animate-in .arrow-3 { animation-delay: 1.7s; }

  @keyframes nodeReveal {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes dashFlow {
    from { stroke-dashoffset: 24; }
    to   { stroke-dashoffset: 0; }
  }

  @keyframes arrowReveal {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pipeline-node,
    .flow-line,
    .flow-arrow {
      opacity: 1 !important;
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
  }

  @media (max-width: 768px) {
    .architecture-diagram {
      padding: 1rem;
    }
  }
</style>
