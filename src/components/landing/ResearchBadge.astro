---
// ResearchBadge.astro — EMNLP 2025 citation, BibTeX expandable, HuggingFace link
---

<section class="research" id="research">
  <div class="research-inner">
    <h2 class="research-heading" data-animate>
      Backed by <span class="accent-text">Research</span>
    </h2>

    <div class="research-card" data-animate data-delay="1">
      <div class="research-badge">
        <i class="ph ph-article"></i>
        <span class="research-badge-text">EMNLP 2025</span>
      </div>

      <h3 class="research-title">
        Discrepancy Detection at the Data Level: Toward Consistent Multilingual Question Answering
      </h3>

      <p class="research-authors">
        Calvo-Bartolomé, Aldana, Cantarero, de Mesa, Arenas-García, Boyd-Graber
      </p>

      <div class="research-actions">
        <a href="https://arxiv.org/abs/2510.11928" class="btn-ghost research-link" target="_blank" rel="noopener noreferrer">
          <i class="ph ph-file-pdf"></i>
          View Paper
        </a>
        <a href="https://huggingface.co/lcalvobartolome/datasets" class="btn-ghost research-link" target="_blank" rel="noopener noreferrer">
          HuggingFace Datasets
        </a>
      </div>

      <!-- Expandable BibTeX -->
      <details class="bibtex-details">
        <summary class="bibtex-summary">
          <i class="ph ph-code"></i>
          Cite (BibTeX)
        </summary>
        <div class="bibtex-content">
          <pre class="bibtex-code" id="bibtex-code">@inproceedings&#123;calvo-bartolome-etal-2025-discrepancy,
  title     = &#123;Discrepancy Detection at the Data Level:
              Toward Consistent Multilingual Question Answering&#125;,
  author    = &#123;Calvo-Bartolom{'\u00e9'} and Aldana and Cantarero
              and de Mesa and Arenas-Garc{'\u00eda'} and Boyd-Graber&#125;,
  booktitle = &#123;Proceedings of EMNLP 2025&#125;,
  year      = &#123;2025&#125;
&#125;</pre>
          <button class="bibtex-copy" id="bibtex-copy" aria-label="Copy BibTeX">
            <i class="ph ph-copy" id="bibtex-copy-icon"></i>
            <span id="bibtex-copy-text">Copy</span>
          </button>
        </div>
      </details>
    </div>
  </div>
</section>

<style>
  .research {
    padding: var(--spacing-section-sm) 1.5rem;
  }

  .research-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .research-heading {
    font-size: var(--text-h2);
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 600;
    text-align: center;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-component);
  }

  .research-card {
    border-left: 4px solid var(--color-amber);
    padding: 2rem;
    background: var(--color-surface);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    border-top: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .research-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    background: var(--color-amber-subtle);
    color: var(--color-amber);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-badge);
    margin-bottom: 1rem;
  }

  .research-title {
    font-size: var(--text-h4);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .research-authors {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .research-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .research-link {
    padding: 0.5rem 1.25rem;
    font-size: var(--text-sm);
  }

  /* BibTeX expandable */
  .bibtex-details {
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
    padding-top: 1rem;
  }

  .bibtex-summary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
    list-style: none;
  }

  .bibtex-summary::-webkit-details-marker {
    display: none;
  }

  .bibtex-summary:hover {
    color: var(--color-electric);
  }

  .bibtex-content {
    position: relative;
    margin-top: 0.75rem;
  }

  .bibtex-code {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    background: var(--color-elevated);
    padding: 1rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    overflow-x: auto;
    white-space: pre;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .bibtex-copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .bibtex-copy:hover {
    color: var(--color-electric);
    border-color: var(--color-electric);
  }
</style>

<script>
  const copyBtn = document.getElementById('bibtex-copy');
  const codeEl = document.getElementById('bibtex-code');
  const copyIcon = document.getElementById('bibtex-copy-icon');
  const copyText = document.getElementById('bibtex-copy-text');

  copyBtn?.addEventListener('click', async () => {
    if (codeEl) {
      try {
        await navigator.clipboard.writeText(codeEl.textContent || '');
        if (copyIcon) copyIcon.className = 'ph ph-check';
        if (copyText) copyText.textContent = 'Copied!';
        setTimeout(() => {
          if (copyIcon) copyIcon.className = 'ph ph-copy';
          if (copyText) copyText.textContent = 'Copy';
        }, 2000);
      } catch (e) {
        // Clipboard API fallback
      }
    }
  });
</script>
